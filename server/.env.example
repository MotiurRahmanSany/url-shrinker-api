HTTP_PORT=your_port #example: 8080
VERSION=1.0.0
SERVICE_NAME=URL Shrinker
JWT_SECRET_KEY=you_secret_key


## Database configuration
DB_HOST=localhost
DB_PORT=your_db_port #example: 5432
DB_USER=postgres
DB_PASSWORD=postgres-password
DB_NAME=url_shrinker_db 
DB_SSL_MODE=false 


# Redis configuration
REDIS_HOST=localhost  
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password #example: redis-password
REDIS_DB=0 

## Goose configuration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=host=localhost port=5433 user=postgres password=postgres-password dbname=url_shrinker_db sslmode=disable
GOOSE_MIGRATION_DIR=./sql/migrations       
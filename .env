HTTP_PORT=8090
VERSION=1.0.0
SERVICE_NAME=URL Shrinker
JWT_SECRET_KEY=another_very_strong_secret_key456


## Database configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres-password
DB_NAME=url_shrinker_db
DB_SSL_MODE=false


# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=      # leave empty if no password
REDIS_DB=0           # default DB index

## Goose configuration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=host=localhost user=postgres password=postgres-password dbname=url_shrinker_db sslmode=disable
GOOSE_MIGRATION_DIR=./sql/migrations       